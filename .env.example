# --- LLM provider selection ---
# Which LLMProvider to use: "claude" (Anthropic API) or "ollama" (local).
LLM_PROVIDER=claude

# --- Claude / Anthropic API ---
# Required when LLM_PROVIDER=claude. Get a key from https://console.anthropic.com/
# (note: this is NOT your claude.ai Pro/Max subscription — API billing is separate).
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-haiku-4-5

# --- Ollama (local model) ---
# Required when LLM_PROVIDER=ollama. Point at a running Ollama server.
# Mode A (docker compose): this value is overridden to
#   http://host.docker.internal:11434 automatically by docker-compose.yml,
#   so anything you set here is ignored inside the container.
# Mode B (API run on host, e.g. `make run`): use http://localhost:11434.
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=hf.co/mradermacher/Llama-Poro-2-8B-Instruct-GGUF:Q6_K
# Local CPU-bound models can be slow with long RAG prompts. Keep output
# bounded unless you know your Ollama setup has enough acceleration.
OLLAMA_TIMEOUT_SECONDS=300
OLLAMA_MAX_TOKENS=256

# --- Embeddings ---
# Sentence-transformers model loaded in-process for the PoC.
# Swap to a remote embedding server by implementing a new EmbeddingProvider.
EMBEDDING_MODEL=BAAI/bge-m3

# --- Qdrant ---
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=syote
# Dimension of the embedding model above (bge-m3 = 1024)
EMBEDDING_DIM=1024

# --- RAG behavior ---
TOP_K=5
MAX_HISTORY_TURNS=4

# --- API server ---
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
