# --- Claude / Anthropic API ---
# Get a key from https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...
# Claude model used for generation
CLAUDE_MODEL=claude-haiku-4-5

# --- Embeddings ---
# Sentence-transformers model loaded in-process for the PoC.
# Swap to a remote embedding server by implementing a new EmbeddingProvider.
EMBEDDING_MODEL=BAAI/bge-m3

# --- Qdrant ---
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=syote
# Dimension of the embedding model above (bge-m3 = 1024)
EMBEDDING_DIM=1024

# --- RAG behavior ---
TOP_K=5
MAX_HISTORY_TURNS=4

# --- API server ---
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
